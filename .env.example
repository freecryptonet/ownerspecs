# ownerspecs.com — environment variables
#
# Public (client-exposed) — must start with NEXT_PUBLIC_

# Google Analytics 4 measurement ID. Get it from analytics.google.com →
# Admin → Data Streams → Web → Measurement ID. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Google Search Console verification token. Get it from
# search.google.com/search-console → Add property → URL prefix
# (https://ownerspecs.com) → HTML tag method → copy the content value.
# Domain-property verification via DNS TXT is preferred long-term (add
# the TXT at Hostinger); the meta-tag variant is the fallback.
NEXT_PUBLIC_GSC_VERIFY=

# Server-only (database, etc) — fill these later when wiring the app to MariaDB

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ownerspecs_app
DB_PASSWORD=
DB_NAME=ownerspecs
